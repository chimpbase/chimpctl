{
  "name": "chimpctl",
  "version": "0.1.0",
  "description": "Customer CLI for Chimpbase Cloud.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "chimpctl": "./bin/chimpctl.ts"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "devDependencies": {
    "@types/node": "^24.6.1",
    "bun-types": "^1.3.10"
  },
  "scripts": {
    "dev": "bun run bin/chimpctl.ts",
    "test": "bun test tests",
    "build": "bun build --compile --minify --target=bun-linux-x64 ./bin/chimpctl.ts --outfile dist/chimpctl",
    "build:linux-x64": "bun build --compile --minify --target=bun-linux-x64 ./bin/chimpctl.ts --outfile dist/chimpctl-linux-x64",
    "build:linux-arm64": "bun build --compile --minify --target=bun-linux-arm64 ./bin/chimpctl.ts --outfile dist/chimpctl-linux-arm64",
    "build:darwin-arm64": "bun build --compile --minify --target=bun-darwin-arm64 ./bin/chimpctl.ts --outfile dist/chimpctl-darwin-arm64",
    "build:darwin-x64": "bun build --compile --minify --target=bun-darwin-x64 ./bin/chimpctl.ts --outfile dist/chimpctl-darwin-x64",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-arm64 && bun run build:darwin-x64"
  }
}
